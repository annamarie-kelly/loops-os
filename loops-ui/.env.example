# Loops OS environment variables
# Copy to .env.local and edit. All values are optional unless marked REQUIRED.

# ─── Vault ────────────────────────────────────────────────────────────
# Absolute path to the markdown vault loops-ui reads/writes. Defaults to
# ../vault-template (the bundled template at the repo root), so the app
# runs out of the box. Point this at your own vault once you're ready.
# LOOPS_UI_VAULT_ROOT=/absolute/path/to/your/vault

# ─── Obsidian ─────────────────────────────────────────────────────────
# Vault name Obsidian uses in obsidian:// URLs (sidebar → vault name at
# the top). Enables "Open in Obsidian" buttons in the detail drawer.
# When unset, those links are hidden rather than rendered dead.
# NEXT_PUBLIC_OBSIDIAN_VAULT=your-vault-name

# ─── Specs / agent kit ────────────────────────────────────────────────
# Folder inside the vault where agent specs live. Defaults to
# "01-Building/Agent Specs". Override if your vault uses a different
# layout for the specs surface.
# LOOPS_SPECS_FOLDER=01-Building/Agent Specs

# ─── Chat panel ───────────────────────────────────────────────────────
# JSON array of { dir, repo } entries for the chat panel's repo picker.
# Each `dir` is an absolute path to a codebase docs folder; HTML files
# inside it surface as "shipped" artifacts in the specs view, and the
# folder is added to the allowed read roots. Defaults to [].
# Example: [{"dir":"/Users/you/repos/backend/docs","repo":"backend"}]
# LOOPS_CODEBASE_DOCS=[{"dir":"/absolute/path/to/repo/docs","repo":"repo-name"}]
