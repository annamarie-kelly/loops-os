{
  "$schema": "./loops.config.schema.json",
  "vault": {
    "scanFolders": [
      "00-Inbox",
      "01-Creating",
      "02-Thinking",
      "03-Living",
      "04-Relating",
      "inbox"
    ],
    "inboxFile": "00-Inbox/manual-loops.md",
    "adoptedFile": "00-Inbox/adopted.md",
    "closeOutsFile": "00-Inbox/close-outs.md"
  },
  "stakeholder": {
    "name": "",
    "tag": "",
    "capacityMax": 8,
    "weeklySummary": false,
    "staleDays": 5
  },
  "self": {
    "capacityMax": 5
  },
  "priorityCaps": {
    "P1Flat": 8,
    "P2Flat": 20
  },
  "scannerStakeholders": [],
  "subgroupHints": [
    { "match": "ceramics", "mode": "build" },
    { "match": "oasis",    "mode": "build" },
    { "match": "digital-oasis", "mode": "build" },
    { "match": "writing",  "mode": "design" },
    { "match": "substack", "mode": "design" },
    { "match": "pattern",  "mode": "design" },
    { "match": "review",   "mode": "communicate" },
    { "match": "schedule", "mode": "communicate" },
    { "match": "health",   "mode": "ops" },
    { "match": "errand",   "mode": "ops" }
  ]
}
