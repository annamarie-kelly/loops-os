{
  "manifest_version": 3,
  "name": "Loops Capture",
  "version": "0.1.0",
  "description": "Capture the current page plus a thought into your Loops triage inbox.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture to Loops"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["activeTab", "storage", "scripting", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Loops capture popup"
    }
  },
  "icons": {
    "128": "icon-128.png"
  }
}
